{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Homeport",
  "version": "0.1.0",
  "identifier": "dev.rileyt.homeport-tray",
  "build": {
    "frontendDist": "dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Homeport",
        "url": "http://127.0.0.1:8083",
        "width": 1280,
        "height": 800,
        "visible": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray-normal.png",
      "iconAsTemplate": false
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "icon": ["icons/tray-normal.png"]
  }
}
