# Hermes messaging secrets (agenix) — Discord
#
#   cd /etc/nixos/secrets
#   agenix -e hermes-env.age
#
# Paste (no quotes on keys):
#
# DISCORD_BOT_TOKEN=your-token-from-discord-developer-portal
# DISCORD_ALLOWED_USERS=your-discord-user-snowflake-id
#
# Spotify (https://hermes-agent.nousresearch.com/docs/user-guide/features/spotify):
# HERMES_SPOTIFY_CLIENT_ID=your-spotify-app-client-id
# HERMES_SPOTIFY_REDIRECT_URI=http://127.0.0.1:43827/spotify/callback
#
# Optional:
# DISCORD_HOME_CHANNEL=channel-id-for-cron-notifications
# DISCORD_FREE_RESPONSE_CHANNELS=channel-id-with-no-mention-required
#
# Get your user ID: Discord Settings → Advanced → Developer Mode →
# right-click your avatar → Copy User ID
#
# Bot setup: https://hermes-agent.nousresearch.com/docs/user-guide/messaging/discord
#
# Email (optional — add to same file):
# EMAIL_ADDRESS=...
# EMAIL_PASSWORD=...
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_POLL_INTERVAL=15
# EMAIL_ALLOWED_USERS=you@example.com
# EMAIL_HOME_ADDRESS=...
